// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  SALES_REP
  HR
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  OFFBOARDED
}

enum EmployeeType {
  DOCTOR           // 醫師
  NURSE            // 護理師
  CONSULTANT       // 諮詢業務
  LOGISTICS        // 後勤
  SCALP_SPECIALIST // 頭管師
}

enum RuleType {
  PERCENTAGE_TIER
  KPI_BONUS
  OVERRIDE
}

enum PeriodType {
  MONTHLY
  QUARTERLY
}

enum CalcStatus {
  DRAFT
  FINALIZED
}

enum ResetRequestStatus {
  PENDING
  RESOLVED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         Role
  employeeId   String?   @unique
  employee     Employee? @relation(fields: [employeeId], references: [id])
  sessions     Session[]
  createdAt    DateTime  @default(now())
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model Department {
  id        String     @id @default(cuid())
  name      String     @unique
  employees Employee[]
  createdAt DateTime   @default(now())
}

model Employee {
  id              String                  @id @default(cuid())
  firstName       String
  lastName        String
  email           String                  @unique
  title           String
  type            EmployeeType            @default(CONSULTANT)
  departmentId    String
  department      Department              @relation(fields: [departmentId], references: [id])
  managerId       String?
  manager         Employee?               @relation("OrgChart", fields: [managerId], references: [id])
  reports         Employee[]              @relation("OrgChart")
  status          EmploymentStatus        @default(ACTIVE)
  hireDate        DateTime
  terminationDate DateTime?
  user            User?
  salesRecords    SalesRecord[]
  targets         Target[]
  calculations    CommissionCalculation[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
}

model SalesRecord {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  customerName String
  amount       Decimal  @db.Decimal(14, 2)
  saleDate     DateTime
  notes        String?
  createdAt    DateTime @default(now())

  @@index([employeeId, saleDate])
}

model CommissionRule {
  id            String    @id @default(cuid())
  name          String
  type          RuleType
  active        Boolean   @default(true)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  config        Json
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([type, active])
}

model Target {
  id          String     @id @default(cuid())
  employeeId  String
  employee    Employee   @relation(fields: [employeeId], references: [id])
  periodType  PeriodType
  periodKey   String
  quotaAmount Decimal    @db.Decimal(14, 2)
  createdAt   DateTime   @default(now())

  @@unique([employeeId, periodType, periodKey])
}

model PasswordResetRequest {
  id         String             @id @default(cuid())
  email      String
  status     ResetRequestStatus @default(PENDING)
  createdAt  DateTime           @default(now())
  resolvedAt DateTime?
  resolvedBy String?

  @@index([status, createdAt])
}

model CommissionCalculation {
  id             String     @id @default(cuid())
  employeeId     String
  employee       Employee   @relation(fields: [employeeId], references: [id])
  periodType     PeriodType
  periodKey      String
  baseCommission Decimal    @db.Decimal(14, 2)
  kpiBonus       Decimal    @db.Decimal(14, 2)
  overrideAmount Decimal    @db.Decimal(14, 2)
  totalAmount    Decimal    @db.Decimal(14, 2)
  breakdown      Json
  status         CalcStatus @default(DRAFT)
  calculatedAt   DateTime   @default(now())
  finalizedAt    DateTime?
  finalizedBy    String?

  @@unique([employeeId, periodType, periodKey])
}
